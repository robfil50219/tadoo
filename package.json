{
  "name": "tadoo",
  "version": "0.4.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "type-check": "tsc --noEmit",
    "test:firestore-rules": "firebase --config firebase.rules-test.json --project demo-tadoo-app emulators:exec --only firestore \"node --test tests/firestore.membership.rules.test.mjs\"",
    "test:storage-rules": "firebase --config firebase.rules-test.json --project demo-tadoo-app emulators:exec --only firestore,storage \"node --test tests/storage.rules.test.mjs\""
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "firebase": "11.8.1",
    "leaflet": "^1.9.4",
    "motion": "^12.42.2",
    "next": "^16.2.9",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "4.0.1",
    "@netlify/plugin-nextjs": "^5.15.12",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.0.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "firebase-tools": "^15.23.0",
    "sass": "^1.69.0",
    "typescript": "^5.3.0"
  }
}
